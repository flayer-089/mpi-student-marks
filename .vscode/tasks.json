{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run MPI",
            "type": "shell",
            "command": "cl.exe",
            "args": [
                "main.cpp",
                "/I\"C:/Program Files (x86)/Microsoft SDKs/MPI/Include\"",
                "/EHsc",
                "/link",
                "/LIBPATH:\"C:/Program Files (x86)/Microsoft SDKs/MPI/Lib/x64\"",
                "msmpi.lib"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Run MPI Program",
            "type": "shell",
            "command": "mpiexec",
            "args": [
                "-n",
                "4",
                "main.exe"
            ],
            "dependsOn": "Build and Run MPI",
            "problemMatcher": []
        }
    ]
}
